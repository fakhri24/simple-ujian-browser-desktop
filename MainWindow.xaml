<Window x:Class="SecureExamBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Secure Exam Browser"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        Background="#1E1E2E">
    <!--
        Penjelasan tiap atribut Window (inti dari Phase 1):

        WindowStyle="None"      -> Hilangkan border, title bar, dan tombol
                                   minimize/maximize/close bawaan Windows.
        ResizeMode="NoResize"   -> Jendela tidak bisa di-resize / di-drag tepinya.
        WindowState="Maximized" -> Jendela langsung memenuhi seluruh layar.
        Topmost="True"          -> Jendela selalu berada di atas semua jendela lain.
        Background="#1E1E2E"    -> Warna latar gelap agar kanvas kosong terlihat jelas.

        Catatan: kombinasi WindowStyle="None" + Maximized membuat jendela
        menutupi seluruh layar TERMASUK area taskbar (mode kiosk sederhana).
    -->

    <Grid>
        <!--
            Grid kosong sebagai kanvas utama.
            Di Phase 2 nanti, WebView2 akan kita letakkan di dalam Grid ini.
            Untuk sekarang hanya ada teks penanda bahwa jendela berhasil tampil.
        -->
        <TextBlock Text="Phase 1: Skeleton Window Aktif"
                   Foreground="#CDD6F4"
                   FontSize="28"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
</Window>
