<Window x:Class="SimpleUjianBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Simple Ujian Browser"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        Background="#1E1E2E">
    <!--
        Atribut Window tetap sama seperti Phase 1 (mode kiosk fullscreen).
        Tambahan baru: namespace "wv2" di baris ke-4 agar kita bisa memakai
        kontrol <wv2:WebView2> dari package Microsoft.Web.WebView2.
    -->

    <Grid>
        <!--
            WebView2 = area browser tempat halaman ujian dirender.
            - x:Name="WebView" supaya bisa diakses dari code-behind.
            - Visibility="Collapsed": disembunyikan dulu sampai halaman siap,
              supaya siswa tidak melihat area putih kosong saat loading.
        -->
        <wv2:WebView2 x:Name="WebView" Visibility="Collapsed" />

        <!--
            Overlay status di tengah layar. Dipakai untuk menampilkan
            pesan loading ATAU pesan error (mis. WebView2 Runtime belum
            terpasang). Akan disembunyikan begitu halaman berhasil dimuat.
        -->
        <TextBlock x:Name="StatusText"
                   Text="Menyiapkan ujian..."
                   Foreground="#CDD6F4"
                   FontSize="24"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   MaxWidth="700"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

        <!--
            Tombol "Keluar" yang terlihat di pojok kanan-atas.
            - Diletakkan PALING AKHIR di dalam Grid supaya selalu tampil di
              atas WebView (anak terakhir dirender paling depan).
            - Click-nya memanggil RequestAdminExit() yang SAMA dengan jalur
              Ctrl+Shift+Q -> tetap wajib memasukkan password admin.
            - Gaya tombol didefinisikan inline lewat ControlTemplate agar
              sudut membulat & punya efek hover, tanpa file resource terpisah.
        -->
        <Button x:Name="ExitButton"
                Content="Keluar"
                Click="ExitButton_Click"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,16,16,0"
                Padding="18,8"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="#1E1E2E"
                Cursor="Hand"
                ToolTip="Keluar dari ujian (perlu password pengawas)">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="#F38BA8"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#EB6F90" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#E64C75" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
