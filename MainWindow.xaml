<Window x:Class="SimpleUjianBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Simple Ujian Browser"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        Background="#1E1E2E">
    <!--
        Atribut Window tetap sama seperti Phase 1 (mode kiosk fullscreen).
        Tambahan baru: namespace "wv2" di baris ke-4 agar kita bisa memakai
        kontrol <wv2:WebView2> dari package Microsoft.Web.WebView2.
    -->

    <Grid>
        <!--
            WebView2 = area browser tempat halaman ujian dirender.
            - x:Name="WebView" supaya bisa diakses dari code-behind.
            - Visibility="Collapsed": disembunyikan dulu sampai halaman siap,
              supaya siswa tidak melihat area putih kosong saat loading.
        -->
        <wv2:WebView2 x:Name="WebView" Visibility="Collapsed" />

        <!--
            Overlay status di tengah layar. Dipakai untuk menampilkan
            pesan loading ATAU pesan error (mis. WebView2 Runtime belum
            terpasang). Akan disembunyikan begitu halaman berhasil dimuat.
        -->
        <TextBlock x:Name="StatusText"
                   Text="Menyiapkan ujian..."
                   Foreground="#CDD6F4"
                   FontSize="24"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   MaxWidth="700"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
</Window>
