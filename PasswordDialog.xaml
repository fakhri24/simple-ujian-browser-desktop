<Window x:Class="SimpleUjianBrowser.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verifikasi Admin"
        Width="400"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#2E2E3E">
    <!--
        Dialog modal kecil untuk meminta password admin.
        - WindowStyle="None": tanpa title bar (tampilan bersih, kiosk-friendly).
        - Topmost="True": tampil DI ATAS jendela ujian yang juga topmost.
        - WindowStartupLocation="CenterOwner": muncul di tengah jendela ujian.
        - ShowInTaskbar="False": tidak muncul sebagai item taskbar terpisah.
    -->
    <Border Padding="24" BorderBrush="#45475A" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Masukkan Password Admin untuk Keluar"
                       Foreground="#CDD6F4"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,16" />

            <!-- PasswordBox menyembunyikan teks yang diketik (jadi titik-titik). -->
            <PasswordBox x:Name="PasswordInput"
                         FontSize="16"
                         Padding="8,6"
                         Background="#1E1E2E"
                         Foreground="#CDD6F4"
                         CaretBrush="#CDD6F4" />

            <!-- Pesan error muncul di sini bila password salah. -->
            <TextBlock x:Name="ErrorText"
                       Text=""
                       Foreground="#F38BA8"
                       FontSize="13"
                       Margin="0,8,0,0"
                       Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button x:Name="CancelButton"
                        Content="Batal"
                        Width="90"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click" />
                <Button x:Name="OkButton"
                        Content="Keluar"
                        Width="90"
                        Height="34"
                        Click="OkButton_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
